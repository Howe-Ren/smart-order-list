		"esbuild": "0.25.5",
		"eslint-plugin-obsidianmd": "0.1.9",
		"globals": "14.0.0",
		"jiti": "2.6.1",
		"tslib": "2.4.0",
		"typescript": "^5.8.3",
		"typescript-eslint": "8.35.1"
	},
	"dependencies": {
		"@codemirror/language": "^6.12.2",
		"@codemirror/state": "^6.5.4",
		"@codemirror/view": "^6.39.16",
		"@lezer/common": "^1.5.1",
		"obsidian": "latest"
	}
