{
	"name": "smart-order-list",
	"version": "2.0.0",
	"description": "Smartly auto-styles and manages standard/nested lists in Obsidian.",
	"main": "main.js",
	"type": "module",
	"scripts": {
		"dev": "node esbuild.config.mjs",
		"build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
